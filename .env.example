# --- Database (PostgreSQL via Neon for production, or local postgres for dev) ---
# Production (Neon): get these from neon.tech → your project → Connection string
# Use the "pooled" connection string for DATABASE_URL and the "direct" (unpooled) for DIRECT_URL.
# For local dev: use a local postgres URL and omit DIRECT_URL (or set both to the same value).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Public URL of this app — used for password-reset links and OAuth redirects. Must match production URL when deployed.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me-with-a-random-string"

# Optional: use first-run setup at /setup to create an admin in the DB instead.
# If set, you can log in with these until an admin exists in the DB.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-me"

# Optional: when set, "Send update" actually sends email via SMTP.
# If unset, messages are stored in the outbox only (no real send).
# For pilots: use Resend (resend.com) SMTP relay — free tier covers early usage.
# Resend SMTP: host=smtp.resend.com port=465 secure=true user=resend pass=<API_KEY>
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@yourdomain.com"

# Optional: for "Connect Gmail" (OAuth). Deployer sets once; users never touch.
# Create credentials in Google Cloud Console (APIs & Services → Credentials → OAuth 2.0 Client ID).
# Authorized redirect URI: https://your-domain/api/auth/gmail/callback (or http://localhost:3000/... for dev).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
