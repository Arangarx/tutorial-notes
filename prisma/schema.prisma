generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum NoteStatus {
  DRAFT
  READY
  SENT
}

enum FeedbackKind {
  BUG
  FEEDBACK
}

model Student {
  id          String       @id @default(uuid())
  name        String
  parentEmail String?      // Saved so tutor doesn't re-enter every time
  createdAt   DateTime     @default(now())
  notes       SessionNote[]
  shareLinks  ShareLink[]
}

model SessionNote {
  id        String    @id @default(uuid())
  studentId String
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  date      DateTime
  topics    String
  homework  String
  nextSteps String
  linksJson String    @default("[]")
  template  String?
  status    NoteStatus @default(DRAFT)
  sentAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([studentId, date])
}

model ShareLink {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  token     String   @unique
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([studentId])
}

model EmailMessage {
  id        String   @id @default(uuid())
  toEmail   String
  subject   String
  bodyText  String
  linkUrl   String
  createdAt DateTime @default(now())
}

model FeedbackItem {
  id        String       @id @default(uuid())
  kind      FeedbackKind
  message   String
  page      String?
  createdAt DateTime     @default(now())
}

model AdminUser {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Singleton: one row. In-app email (SMTP) settings so deployer doesn't hunt for .env.
model EmailConfig {
  id        String   @id @default(uuid())
  host      String
  port      Int      @default(587)
  secure    Boolean  @default(false)
  user      String
  password  String   // Store in DB; protect DB access in production
  fromEmail String?
  updatedAt DateTime @updatedAt
}

// OAuth email connections: "Connect Gmail" / "Connect Outlook" — one per provider.
model OAuthEmailConnection {
  id           String   @id @default(uuid())
  provider     String   // "gmail" | "outlook"
  refreshToken String
  email        String   // connected address (e.g. user@gmail.com)
  updatedAt    DateTime @updatedAt
}

